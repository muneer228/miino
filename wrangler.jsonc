{
  "name": "miino",
  "compatibility_date": "2026-04-07",
  "assets": {
    "directory": ".",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "miino.xyz",
      "custom_domain": true
    },
    {
      "pattern": "www.miino.xyz",
      "custom_domain": true
    }
  ]
}
